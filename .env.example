# ============================================
# FUEGA.AI - Environment Variables Template
# ============================================
# Copy to .env and fill in your values
# NEVER commit .env to git
# ============================================

# === Core AI ===
ANTHROPIC_API_KEY=sk-ant-your-key-here

# === Database ===
DATABASE_URL=postgresql://user:password@localhost:5432/fuega

# === Authentication ===
JWT_SECRET=generate-with-openssl-rand-base64-48
IP_SALT=generate-with-openssl-rand-base64-24

# === Server ===
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Push Notifications (VAPID) ===
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=   # Public key exposed to browser clients
VAPID_PUBLIC_KEY=               # Same value as above, for server-side use
VAPID_PRIVATE_KEY=              # Keep secret — never expose to clients
VAPID_EMAIL=mailto:admin@fuega.ai

# === Monitoring & Alerting ===
# Secret for /api/monitoring/* endpoints (generate random 32-char string)
MONITORING_SECRET=
# Secret for /api/monitoring/cron endpoint (generate random 32-char string)
CRON_SECRET=
# Discord/Slack webhook URL for alert notifications
ALERT_WEBHOOK_URL=
# Minimum log level: debug, info, warn, error (default: info in production, debug in dev)
LOG_LEVEL=info

# === Railway ===
# Set by Railway automatically; used in monitoring alerts
RAILWAY_ENVIRONMENT=production

# === Feature Flags ===
# Set to "true" or "1" to enable; defaults to disabled (safe state)
ENABLE_BADGE_DISTRIBUTION=false
ENABLE_TIP_JAR=false
ENABLE_NOTIFICATIONS=false
ENABLE_COSMETICS_SHOP=false

# PUBLIC_LAUNCH_DATE for Founder badge eligibility (ISO date)
PUBLIC_LAUNCH_DATE=2027-01-01
